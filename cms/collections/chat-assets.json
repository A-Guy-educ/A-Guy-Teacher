{
  "name": "chat-assets",
  "label": "Chat Assets",
  "adapter": "mongodb",
  "mcpName": "chat_assets",
  "source": {
    "collection": "chat-assets",
    "idField": "_id"
  },
  "titleField": "_id",
  "searchFields": [
    "mimeType",
    "originalFilename",
    "pathname"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "createdBy",
      "type": "text",
      "label": "Created By"
    },
    {
      "name": "expiresAt",
      "type": "date",
      "label": "Expires At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "filesize",
      "type": "number",
      "label": "Filesize",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "mimeType",
      "type": "select",
      "label": "Mime Type",
      "options": [
        {
          "label": "image/png",
          "value": "image/png"
        }
      ]
    },
    {
      "name": "originalFilename",
      "type": "text",
      "label": "Original Filename"
    },
    {
      "name": "pathname",
      "type": "text",
      "label": "Pathname"
    },
    {
      "name": "retentionPolicy",
      "type": "text",
      "label": "Retention Policy"
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "uploadSessionId",
      "type": "text",
      "label": "Upload Session Id",
      "hidden": true
    },
    {
      "name": "url",
      "type": "text",
      "label": "Url"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "_id",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "mimeType"
        },
        {
          "name": "originalFilename"
        },
        {
          "name": "pathname"
        },
        {
          "name": "tenant"
        },
        {
          "name": "expiresAt"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "expiresAt"
        },
        {
          "name": "filesize"
        },
        {
          "name": "mimeType"
        },
        {
          "name": "originalFilename"
        },
        {
          "name": "pathname"
        },
        {
          "name": "retentionPolicy"
        },
        {
          "name": "tenant"
        },
        {
          "name": "url"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "createdBy"
        },
        {
          "name": "expiresAt"
        },
        {
          "name": "filesize"
        },
        {
          "name": "mimeType"
        },
        {
          "name": "originalFilename"
        },
        {
          "name": "pathname"
        },
        {
          "name": "retentionPolicy"
        },
        {
          "name": "tenant"
        },
        {
          "name": "url"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "mimeType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "originalFilename",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "pathname",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "expiresAt",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    }
  ]
}

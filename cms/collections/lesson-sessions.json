{
  "name": "lesson-sessions",
  "label": "Lesson Sessions",
  "adapter": "mongodb",
  "mcpName": "lesson_sessions",
  "source": {
    "collection": "lesson-sessions",
    "idField": "_id"
  },
  "titleField": "_id",
  "searchFields": [
    "status"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "status",
      "type": "select",
      "label": "Status",
      "options": [
        {
          "label": "active",
          "value": "active"
        },
        {
          "label": "completed",
          "value": "completed"
        }
      ]
    },
    {
      "name": "completedAt",
      "type": "date",
      "label": "Completed At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "currentBlockIndex",
      "type": "number",
      "label": "Current Block Index",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "currentPhase",
      "type": "text",
      "label": "Current Phase"
    },
    {
      "name": "history",
      "type": "array",
      "label": "History",
      "storage": {
        "kind": "array"
      }
    },
    {
      "name": "lesson",
      "type": "relation",
      "label": "Lesson",
      "storage": {
        "kind": "objectId"
      },
      "target": "lessons",
      "labelField": "title"
    },
    {
      "name": "processedActions",
      "type": "array",
      "label": "Processed Actions",
      "storage": {
        "kind": "array"
      }
    },
    {
      "name": "remediationCounts",
      "type": "object",
      "label": "Remediation Counts",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "schemaVersion",
      "type": "number",
      "label": "Schema Version",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "skillScore",
      "type": "number",
      "label": "Skill Score",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "startedAt",
      "type": "date",
      "label": "Started At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "user",
      "type": "relation",
      "label": "User",
      "storage": {
        "kind": "objectId"
      },
      "target": "users",
      "labelField": "name"
    },
    {
      "name": "version",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "_id",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "status"
        },
        {
          "name": "lesson"
        },
        {
          "name": "tenant"
        },
        {
          "name": "user"
        },
        {
          "name": "completedAt"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "status"
        },
        {
          "name": "completedAt"
        },
        {
          "name": "currentBlockIndex"
        },
        {
          "name": "currentPhase"
        },
        {
          "name": "history"
        },
        {
          "name": "lesson"
        },
        {
          "name": "processedActions"
        },
        {
          "name": "remediationCounts"
        },
        {
          "name": "schemaVersion"
        },
        {
          "name": "skillScore"
        },
        {
          "name": "startedAt"
        },
        {
          "name": "tenant"
        },
        {
          "name": "user"
        },
        {
          "name": "version"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "status"
        },
        {
          "name": "completedAt"
        },
        {
          "name": "currentBlockIndex"
        },
        {
          "name": "currentPhase"
        },
        {
          "name": "history"
        },
        {
          "name": "lesson"
        },
        {
          "name": "processedActions"
        },
        {
          "name": "remediationCounts"
        },
        {
          "name": "schemaVersion"
        },
        {
          "name": "skillScore"
        },
        {
          "name": "startedAt"
        },
        {
          "name": "tenant"
        },
        {
          "name": "user"
        },
        {
          "name": "version"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "status",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "lesson",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "user",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "completedAt",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    }
  ]
}

{
  "name": "payload-preferences",
  "label": "Payload Preferences",
  "adapter": "mongodb",
  "mcpName": "payload_preferences",
  "source": {
    "collection": "payload-preferences",
    "idField": "_id"
  },
  "titleField": "key",
  "searchFields": [
    "key"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "key",
      "type": "text",
      "label": "Key"
    },
    {
      "name": "user",
      "type": "object",
      "label": "User",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "value",
      "type": "object",
      "label": "Value",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "key",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "updatedAt"
        },
        {
          "name": "createdAt"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "key"
        },
        {
          "name": "user"
        },
        {
          "name": "value"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "key"
        },
        {
          "name": "user"
        },
        {
          "name": "value"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "key",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "updatedAt",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    },
    {
      "field": "createdAt",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    }
  ]
}

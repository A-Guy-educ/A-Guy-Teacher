{
  "name": "payload-jobs",
  "label": "Payload Jobs",
  "adapter": "mongodb",
  "mcpName": "payload_jobs",
  "source": {
    "collection": "payload-jobs",
    "idField": "_id"
  },
  "titleField": "_id",
  "searchFields": [
    "taskSlug"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "completedAt",
      "type": "date",
      "label": "Completed At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "hasError",
      "type": "boolean",
      "label": "Has Error",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "input",
      "type": "object",
      "label": "Input",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "jobOutput",
      "type": "object",
      "label": "Job Output",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "lockExpiresAt",
      "type": "date",
      "label": "Lock Expires At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "processing",
      "type": "boolean",
      "label": "Processing",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "queue",
      "type": "text",
      "label": "Queue"
    },
    {
      "name": "startedAt",
      "type": "date",
      "label": "Started At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "taskSlug",
      "type": "text",
      "label": "Task Slug"
    },
    {
      "name": "totalTried",
      "type": "number",
      "label": "Total Tried",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "_id",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "taskSlug"
        },
        {
          "name": "hasError"
        },
        {
          "name": "processing"
        },
        {
          "name": "completedAt"
        },
        {
          "name": "lockExpiresAt"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "completedAt"
        },
        {
          "name": "hasError"
        },
        {
          "name": "input"
        },
        {
          "name": "jobOutput"
        },
        {
          "name": "lockExpiresAt"
        },
        {
          "name": "processing"
        },
        {
          "name": "queue"
        },
        {
          "name": "startedAt"
        },
        {
          "name": "taskSlug"
        },
        {
          "name": "totalTried"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "completedAt"
        },
        {
          "name": "hasError"
        },
        {
          "name": "input"
        },
        {
          "name": "jobOutput"
        },
        {
          "name": "lockExpiresAt"
        },
        {
          "name": "processing"
        },
        {
          "name": "queue"
        },
        {
          "name": "startedAt"
        },
        {
          "name": "taskSlug"
        },
        {
          "name": "totalTried"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "taskSlug",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "hasError",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "processing",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "completedAt",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    },
    {
      "field": "lockExpiresAt",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    }
  ]
}

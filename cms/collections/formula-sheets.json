{
  "name": "formula-sheets",
  "label": "Formula Sheets",
  "adapter": "mongodb",
  "mcpName": "formula_sheets",
  "source": {
    "collection": "formula-sheets",
    "idField": "_id"
  },
  "titleField": "title",
  "searchFields": [
    "title",
    "name",
    "status",
    "contentType",
    "locale"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "title",
      "type": "text",
      "label": "Title"
    },
    {
      "name": "name",
      "type": "text",
      "label": "Name"
    },
    {
      "name": "status",
      "type": "select",
      "label": "Status",
      "options": [
        {
          "label": "published",
          "value": "published"
        }
      ]
    },
    {
      "name": "bodyBlocks",
      "type": "array",
      "label": "Body Blocks",
      "storage": {
        "kind": "array"
      }
    },
    {
      "name": "content",
      "type": "object",
      "label": "Content",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "contentType",
      "type": "select",
      "label": "Content Type",
      "options": [
        {
          "label": "blocks",
          "value": "blocks"
        }
      ]
    },
    {
      "name": "createdBy",
      "type": "text",
      "label": "Created By",
      "storage": {
        "kind": "objectId"
      }
    },
    {
      "name": "locale",
      "type": "select",
      "label": "Locale",
      "options": [
        {
          "label": "he",
          "value": "he"
        }
      ]
    },
    {
      "name": "pdfFile",
      "type": "text",
      "label": "Pdf File",
      "storage": {
        "kind": "objectId"
      }
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "title",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "contentType"
        },
        {
          "name": "locale"
        },
        {
          "name": "name"
        },
        {
          "name": "status"
        },
        {
          "name": "tenant"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "title"
        },
        {
          "name": "name"
        },
        {
          "name": "status"
        },
        {
          "name": "bodyBlocks"
        },
        {
          "name": "content"
        },
        {
          "name": "contentType"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "locale"
        },
        {
          "name": "pdfFile"
        },
        {
          "name": "tenant"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "title"
        },
        {
          "name": "name"
        },
        {
          "name": "status"
        },
        {
          "name": "bodyBlocks"
        },
        {
          "name": "content"
        },
        {
          "name": "contentType"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "locale"
        },
        {
          "name": "pdfFile"
        },
        {
          "name": "tenant"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "title",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "contentType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "locale",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "name",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "status",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    }
  ]
}

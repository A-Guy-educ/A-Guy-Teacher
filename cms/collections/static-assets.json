        },
        {
          "name": "contentType"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "filename"
        },
        {
          "name": "filesize"
        },
        {
          "name": "fileSize"
        },
        {
          "name": "key"
        },
        {
          "name": "manifest"
        },
        {
          "name": "mimeType"
        },
        {
          "name": "publicUrl"
        },
        {
          "name": "version"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "key",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "assetType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "contentType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "filename",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "mimeType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "status",
      "operators": [
        "equals",
        "in"
      ]
    }
  ]
}

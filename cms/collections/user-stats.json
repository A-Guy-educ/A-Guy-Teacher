{
  "name": "user-stats",
  "label": "User Stats",
  "adapter": "mongodb",
  "mcpName": "user_stats",
  "source": {
    "collection": "user-stats",
    "idField": "_id"
  },
  "titleField": "_id",
  "searchFields": [],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "activityLog",
      "type": "array",
      "label": "Activity Log",
      "storage": {
        "kind": "array"
      }
    },
    {
      "name": "currentStreak",
      "type": "number",
      "label": "Current Streak",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "lastActiveDate",
      "type": "date",
      "label": "Last Active Date",
      "storage": {
        "kind": "dateString"
      }
    },
    {
      "name": "lastHeartbeatAt",
      "type": "date",
      "label": "Last Heartbeat At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "longestStreak",
      "type": "number",
      "label": "Longest Streak",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "returnCount",
      "type": "number",
      "label": "Return Count",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "totalTimeSpentSeconds",
      "type": "number",
      "label": "Total Time Spent Seconds",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "user",
      "type": "relation",
      "label": "User",
      "storage": {
        "kind": "objectId"
      },
      "target": "users",
      "labelField": "name"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "_id",
          "role": "primary",
          "width": "fill"

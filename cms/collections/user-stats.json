    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "user",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "currentStreak",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    },
    {
      "field": "lastActiveDate",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    },
    {
      "field": "lastHeartbeatAt",
      "operators": [
        "equals",

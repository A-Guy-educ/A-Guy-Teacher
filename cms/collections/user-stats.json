        },
        {
          "name": "activityLog"
        },
        {
          "name": "currentStreak"
        },
        {
          "name": "lastActiveDate"
        },
        {
          "name": "lastHeartbeatAt"
        },
        {
          "name": "longestStreak"
        },
        {
          "name": "returnCount"
        },
        {
          "name": "tenant"
        },
        {
          "name": "totalTimeSpentSeconds"
        },
        {
          "name": "user"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "activityLog"
        },
        {
          "name": "currentStreak"
        },
        {
          "name": "lastActiveDate"
        },
        {
          "name": "lastHeartbeatAt"
        },
        {
          "name": "longestStreak"
        },
        {
          "name": "returnCount"
        },
        {
          "name": "tenant"
        },
        {
          "name": "totalTimeSpentSeconds"
        },
        {
          "name": "user"
        }
      ]
    }
  },

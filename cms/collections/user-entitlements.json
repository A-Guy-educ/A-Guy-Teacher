{
  "name": "user-entitlements",
  "label": "User Entitlements",
  "adapter": "mongodb",
  "mcpName": "user_entitlements",
  "source": {
    "collection": "user-entitlements",
    "idField": "_id"
  },
  "titleField": "_id",
  "searchFields": [
    "contentType"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "contentType",
      "type": "select",
      "label": "Content Type",
      "options": [
        {
          "label": "course",
          "value": "course"
        }
      ]
    },
    {
      "name": "course",
      "type": "relation",
      "label": "Course",
      "storage": {
        "kind": "objectId"
      },
      "target": "courses",
      "labelField": "title"
    },
    {
      "name": "grantMethod",
      "type": "text",
      "label": "Grant Method"
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "user",
      "type": "relation",
      "label": "User",
      "storage": {
        "kind": "objectId"
      },
      "target": "users",
      "labelField": "name"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "_id",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "contentType"
        },
        {
          "name": "course"
        },
        {
          "name": "tenant"
        },
        {
          "name": "user"
        },
        {
          "name": "grantMethod"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "contentType"
        },
        {
          "name": "course"
        },
        {
          "name": "grantMethod"
        },
        {
          "name": "tenant"
        },
        {
          "name": "user"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "contentType"
        },
        {
          "name": "course"
        },
        {
          "name": "grantMethod"
        },
        {
          "name": "tenant"
        },
        {
          "name": "user"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "contentType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "course",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "user",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "grantMethod",
      "operators": [
        "contains",
        "equals"
      ]
    }
  ]
}

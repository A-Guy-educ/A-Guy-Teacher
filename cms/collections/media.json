{
  "name": "media",
  "label": "Media",
  "adapter": "mongodb",
  "mcpName": "media",
  "source": {
    "collection": "media",
    "idField": "_id"
  },
  "titleField": "_id",
  "searchFields": [
    "filename",
    "mimeType",
    "type"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "alt",
      "type": "text",
      "label": "Alt"
    },
    {
      "name": "createdBy",
      "type": "text",
      "label": "Created By",
      "storage": {
        "kind": "objectId"
      }
    },
    {
      "name": "expiresAt",
      "type": "date",
      "label": "Expires At",
      "storage": {
        "kind": "date"
      }
    },
    {
      "name": "filename",
      "type": "text",
      "label": "Filename"
    },
    {
      "name": "filesize",
      "type": "number",
      "label": "Filesize",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "focalX",
      "type": "number",
      "label": "Focal X",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "focalY",
      "type": "number",
      "label": "Focal Y",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "height",
      "type": "number",
      "label": "Height",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "mimeType",
      "type": "select",
      "label": "Mime Type",
      "options": [
        {
          "label": "application/octet-stream",
          "value": "application/octet-stream"
        },
        {
          "label": "application/pdf",
          "value": "application/pdf"
        },
        {
          "label": "image/gif",
          "value": "image/gif"
        },
        {
          "label": "image/jpeg",
          "value": "image/jpeg"
        },
        {
          "label": "image/png",
          "value": "image/png"
        },
        {
          "label": "image/svg+xml",
          "value": "image/svg+xml"
        },
        {
          "label": "image/webp",
          "value": "image/webp"
        },
        {
          "label": "text/rtf",
          "value": "text/rtf"
        }
      ]
    },
    {
      "name": "retentionPolicy",
      "type": "text",
      "label": "Retention Policy"
    },
    {
      "name": "sizes",
      "type": "object",
      "label": "Sizes",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "thumbnailURL",
      "type": "text",
      "label": "Thumbnail URL"
    },
    {
      "name": "type",
      "type": "select",
      "label": "Type",
      "options": [
        {
          "label": "image",
          "value": "image"
        },
        {
          "label": "other",
          "value": "other"
        },
        {
          "label": "pdf",
          "value": "pdf"
        },
        {
          "label": "svg",
          "value": "svg"
        }
      ]
    },
    {
      "name": "url",
      "type": "textarea",
      "label": "Url"
    },
    {
      "name": "width",
      "type": "number",
      "label": "Width",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "_id",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "filename"
        },
        {
          "name": "mimeType"
        },
        {
          "name": "type"
        },
        {
          "name": "tenant"
        },
        {
          "name": "expiresAt"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "alt"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "expiresAt"
        },
        {
          "name": "filename"
        },
        {
          "name": "filesize"
        },
        {
          "name": "focalX"
        },
        {
          "name": "focalY"
        },
        {
          "name": "height"
        },
        {
          "name": "mimeType"
        },
        {
          "name": "retentionPolicy"
        },
        {
          "name": "sizes"
        },
        {
          "name": "tenant"
        },
        {
          "name": "thumbnailURL"
        },
        {
          "name": "type"
        },
        {
          "name": "url"
        },
        {
          "name": "width"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "alt"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "expiresAt"
        },
        {
          "name": "filename"
        },
        {
          "name": "filesize"
        },
        {
          "name": "focalX"
        },
        {
          "name": "focalY"
        },
        {
          "name": "height"
        },
        {
          "name": "mimeType"
        },
        {
          "name": "retentionPolicy"
        },
        {
          "name": "sizes"
        },
        {
          "name": "tenant"
        },
        {
          "name": "thumbnailURL"
        },
        {
          "name": "type"
        },
        {
          "name": "url"
        },
        {
          "name": "width"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "filename",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "mimeType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "type",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "expiresAt",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    }
  ]
}

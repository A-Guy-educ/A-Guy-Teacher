        {
          "label": "media",
          "value": "media"
        },
        {
          "label": "pdf",
          "value": "pdf"
        }
      ]
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true

    {
      "name": "prompt",
      "type": "relation",
      "label": "Prompt",
      "storage": {
        "kind": "objectId"
      },
      "target": "prompts",
      "labelField": "title"
    },
    {
      "name": "remediationEnabled",
      "type": "boolean",
      "label": "Remediation Enabled",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "slug",
      "type": "text",
      "label": "Slug"
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "translatedFrom",
      "type": "text",
      "label": "Translated From",
      "storage": {
        "kind": "objectId"
      }
    },
    {
      "name": "type",
      "type": "select",
      "label": "Type",
      "options": [
        {
          "label": "exam",
          "value": "exam"
        },
        {
          "label": "learning",
          "value": "learning"
        },
        {
          "label": "practice",
          "value": "practice"
        }
      ]
    },
    {
      "name": "typewriterEnabled",
      "type": "boolean",
      "label": "Typewriter Enabled",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "visibleRenderers",

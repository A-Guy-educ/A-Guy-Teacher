        {
          "label": "en",
          "value": "en"
        },
        {
          "label": "he",
          "value": "he"
        }
      ]
    },
    {
      "name": "prerequisites",
      "type": "array",
      "label": "Prerequisites",
      "storage": {
        "kind": "objectIdArray"
      }

{
  "name": "lessons",
  "label": "Lessons",
  "adapter": "mongodb",
  "mcpName": "lessons",
  "source": {
    "collection": "lessons",
    "idField": "_id"
  },
  "titleField": "title",
  "searchFields": [
    "title",
    "status",
    "accessType",
    "adminTitle",
    "contentStatus",
    "description",
    "introDescription",
    "locale"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "title",
      "type": "text",
      "label": "Title"
    },
    {
      "name": "status",
      "type": "select",
      "label": "Status",
      "options": [
        {
          "label": "draft",
          "value": "draft"
        },
        {
          "label": "published",
          "value": "published"
        }
      ]
    },
    {
      "name": "order",
      "type": "number",
      "label": "Order",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "accessType",
      "type": "select",
      "label": "Access Type",
      "options": [
        {
          "label": "free",
          "value": "free"
        },
        {
          "label": "gated",
          "value": "gated"
        },
        {
          "label": "inherit",
          "value": "inherit"
        }
      ]
    },
    {
      "name": "adaptivityEnabled",
      "type": "boolean",
      "label": "Adaptivity Enabled",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "adminTitle",
      "type": "text",
      "label": "Admin Title"
    },
    {
      "name": "blocks",
      "type": "textarea",
      "label": "Blocks"
    },
    {
      "name": "chapter",
      "type": "relation",
      "label": "Chapter",
      "storage": {
        "kind": "objectId"
      },
      "target": "chapters",
      "labelField": "title"
    },
    {
      "name": "contentFiles",
      "type": "array",
      "label": "Content Files",
      "storage": {
        "kind": "objectIdArray"
      }
    },
    {
      "name": "contentStatus",
      "type": "select",
      "label": "Content Status",
      "options": [
        {
          "label": "none",
          "value": "none"
        },
        {
          "label": "soon",
          "value": "soon"
        }
      ]
    },
    {
      "name": "contentStatusVisible",
      "type": "boolean",
      "label": "Content Status Visible",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "course",
      "type": "relation",
      "label": "Course",
      "storage": {
        "kind": "objectId"
      },
      "target": "courses",
      "labelField": "title"

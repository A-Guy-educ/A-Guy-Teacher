{
  "name": "content-pages",
  "label": "Content Pages",
  "adapter": "mongodb",
  "mcpName": "content_pages",
  "source": {
    "collection": "content-pages",
    "idField": "_id"
  },
  "titleField": "title",
  "searchFields": [
    "title",
    "status",
    "slug"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "title",
      "type": "text",
      "label": "Title"
    },
    {
      "name": "status",
      "type": "select",
      "label": "Status",
      "options": [
        {
          "label": "published",
          "value": "published"
        }
      ]
    },
    {
      "name": "body",
      "type": "array",
      "label": "Body",
      "storage": {
        "kind": "array"
      }
    },
    {
      "name": "createdBy",
      "type": "text",
      "label": "Created By",
      "storage": {
        "kind": "objectId"
      }
    },
    {
      "name": "defaultBlockSpacing",
      "type": "text",
      "label": "Default Block Spacing"
    },
    {
      "name": "isActive",
      "type": "boolean",
      "label": "Is Active",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "lesson",
      "type": "relation",
      "label": "Lesson",
      "storage": {
        "kind": "objectId"
      },
      "target": "lessons",
      "labelField": "title"
    },
    {
      "name": "slug",
      "type": "text",
      "label": "Slug"
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "title",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "slug"
        },
        {
          "name": "status"
        },
        {
          "name": "lesson"
        },
        {
          "name": "tenant"
        },
        {
          "name": "isActive"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "title"
        },
        {
          "name": "status"
        },
        {
          "name": "body"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "defaultBlockSpacing"
        },
        {
          "name": "isActive"
        },
        {
          "name": "lesson"
        },
        {
          "name": "slug"
        },
        {
          "name": "tenant"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "title"
        },
        {
          "name": "status"
        },
        {
          "name": "body"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "defaultBlockSpacing"
        },
        {
          "name": "isActive"
        },
        {
          "name": "lesson"
        },
        {
          "name": "slug"
        },
        {
          "name": "tenant"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "title",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "slug",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "status",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "lesson",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "isActive",
      "operators": [
        "equals"
      ]
    }
  ]
}

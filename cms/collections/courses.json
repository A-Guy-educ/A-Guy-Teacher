        },
        {
          "name": "meta"
        },
        {
          "name": "pageAccessType"
        },
        {
          "name": "prompt"
        },
        {
          "name": "slug"
        },
        {
          "name": "tenant"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "title",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "accessType",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "contentStatus",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "courseLabel",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "locale",
      "operators": [
        "equals",

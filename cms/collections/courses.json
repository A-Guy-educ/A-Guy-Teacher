        },
        {
          "name": "locale"
        },
        {
          "name": "meta"
        },
        {
          "name": "pageAccessType"
        },
        {
          "name": "prompt"
        },
        {
          "name": "slug"
        },
        {
          "name": "tenant"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {

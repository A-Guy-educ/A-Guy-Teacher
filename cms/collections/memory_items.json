        {
          "label": "active",
          "value": "active"
        }
      ]
    },
    {
      "name": "contextKey",
      "type": "text",
      "label": "Context Key"
    },
    {
      "name": "contextLevel",
      "type": "text",
      "label": "Context Level"
    },
    {
      "name": "conversationId",
      "type": "text",
      "label": "Conversation Id"
    },
    {
      "name": "embedding",
      "type": "array",
      "label": "Embedding",
      "storage": {
        "kind": "array"
      }
    },
    {
      "name": "importance",
      "type": "number",
      "label": "Importance",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "source",
      "type": "object",
      "label": "Source",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "text",
      "type": "text",
      "label": "Text"
    },
    {
      "name": "type",
      "type": "select",
      "label": "Type",
      "options": [
        {
          "label": "constraint",
          "value": "constraint"
        },
        {
          "label": "decision",
          "value": "decision"
        },
        {
          "label": "fact",
          "value": "fact"
        },
        {
          "label": "open_loop",
          "value": "open_loop"
        },
        {
          "label": "preference",
          "value": "preference"
        },
        {
          "label": "profile",
          "value": "profile"

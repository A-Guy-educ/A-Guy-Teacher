      "type": "relation",
      "label": "User Id",
      "storage": {
        "kind": "objectId"
      },
      "target": "users",
      "labelField": "name"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true

    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "status",

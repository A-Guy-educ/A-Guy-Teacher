      "label": "Discount Display"
    },
    {
      "name": "discountType",
      "type": "select",
      "label": "Discount Type",
      "options": [
        {
          "label": "fixed",
          "value": "fixed"
        }
      ]
    },
    {
      "name": "discountValue",
      "type": "number",
      "label": "Discount Value",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "expiresDisplay",
      "type": "text",
      "label": "Expires Display"
    },
    {
      "name": "isActive",
      "type": "boolean",
      "label": "Is Active",
      "storage": {
        "kind": "boolean"
      }

        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "status",
      "type": "select",
      "label": "Status",
      "options": [
        {
          "label": "Active",
          "value": "Active"
        }
      ]
    },
    {
      "name": "applicableProducts",
      "type": "array",
      "label": "Applicable Products",
      "storage": {
        "kind": "objectIdArray"
      }
    },
    {
      "name": "code",
      "type": "text",
      "label": "Code"
    },
    {
      "name": "createdBy",
      "type": "text",
      "label": "Created By",
      "storage": {
        "kind": "objectId"
      }
    },
    {

{
  "name": "coupons",
  "label": "Coupons",
  "adapter": "mongodb",
  "mcpName": "coupons",
  "source": {
    "collection": "coupons",
    "idField": "_id"
  },
  "titleField": "code",
  "searchFields": [
    "code",
    "status",
    "currency",
    "discountType"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,

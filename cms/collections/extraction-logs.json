          "name": "pipelineVersion"
        },
        {
          "name": "processingTimeMs"
        },
        {
          "name": "prompt"
        },
        {
          "name": "promptVersion"
        },
        {
          "name": "rawResponse"
        },
        {
          "name": "stage"
        },
        {
          "name": "tenant"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "status"
        },
        {
          "name": "errorMessage"
        },
        {
          "name": "exercise"
        },
        {
          "name": "lesson"
        },
        {
          "name": "media"
        },
        {
          "name": "model"
        },
        {
          "name": "parsedPayload"
        },
        {
          "name": "pipelineVersion"
        },
        {
          "name": "processingTimeMs"
        },
        {
          "name": "prompt"
        },
        {
          "name": "promptVersion"
        },
        {
          "name": "rawResponse"
        },
        {
          "name": "stage"
        },
        {
          "name": "tenant"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "status",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "exercise",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "lesson",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "media",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "prompt",
      "operators": [
        "equals"
      ]
    }
  ]
}

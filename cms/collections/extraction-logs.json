{
  "name": "extraction-logs",
  "label": "Extraction Logs",
  "adapter": "mongodb",
  "mcpName": "extraction_logs",
  "source": {
    "collection": "extraction-logs",
    "idField": "_id"
  },
  "titleField": "_id",
  "searchFields": [
    "status"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "status",
      "type": "select",
      "label": "Status",
      "options": [
        {
          "label": "failed",
          "value": "failed"
        },
        {
          "label": "success",
          "value": "success"
        }
      ]
    },
    {
      "name": "errorMessage",
      "type": "textarea",
      "label": "Error Message"
    },
    {
      "name": "exercise",
      "type": "relation",
      "label": "Exercise",
      "storage": {
        "kind": "objectId"
      },
      "target": "exercises",
      "labelField": "title"
    },
    {
      "name": "lesson",
      "type": "relation",
      "label": "Lesson",
      "storage": {
        "kind": "objectId"
      },
      "target": "lessons",
      "labelField": "title"
    },
    {
      "name": "media",
      "type": "relation",
      "label": "Media",
      "storage": {
        "kind": "objectId"
      },
      "target": "media",
      "labelField": "_id"
    },
    {
      "name": "model",
      "type": "text",
      "label": "Model"
    },
    {
      "name": "parsedPayload",
      "type": "object",
      "label": "Parsed Payload",
      "storage": {
        "kind": "object"
      }
    },
    {
      "name": "pipelineVersion",
      "type": "number",
      "label": "Pipeline Version",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "processingTimeMs",
      "type": "number",
      "label": "Processing Time Ms",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "prompt",
      "type": "relation",
      "label": "Prompt",
      "storage": {
        "kind": "objectId"
      },
      "target": "prompts",
      "labelField": "title"
    },
    {
      "name": "promptVersion",
      "type": "text",
      "label": "Prompt Version"
    },
    {
      "name": "rawResponse",
      "type": "textarea",
      "label": "Raw Response"
    },
    {
      "name": "stage",
      "type": "text",
      "label": "Stage"
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "_id",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "status"
        },
        {
          "name": "exercise"
        },
        {
          "name": "lesson"
        },
        {
          "name": "media"
        },
        {
          "name": "prompt"
        }
      ]
    },
    "detail": {

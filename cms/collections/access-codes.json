{
  "name": "access-codes",
  "label": "Access Codes",
  "adapter": "mongodb",
  "mcpName": "access_codes",
  "source": {
    "collection": "access-codes",
    "idField": "_id"
  },
  "titleField": "code",
  "searchFields": [
    "code"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "_id",
      "type": "id",
      "label": "ID",
      "storage": {
        "kind": "objectId"
      },
      "readOnly": true
    },
    {
      "name": "code",
      "type": "text",
      "label": "Code"
    },
    {
      "name": "course",
      "type": "relation",
      "label": "Course",
      "storage": {
        "kind": "objectId"
      },
      "target": "courses",
      "labelField": "title"
    },
    {
      "name": "createdBy",
      "type": "text",
      "label": "Created By",
      "storage": {
        "kind": "objectId"
      }
    },
    {
      "name": "currentUses",
      "type": "number",
      "label": "Current Uses",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "isActive",
      "type": "boolean",
      "label": "Is Active",
      "storage": {
        "kind": "boolean"
      }
    },
    {
      "name": "maxUses",
      "type": "number",
      "label": "Max Uses",
      "storage": {
        "kind": "number"
      }
    },
    {
      "name": "tenant",
      "type": "relation",
      "label": "Tenant",
      "storage": {
        "kind": "objectId"
      },
      "target": "tenants",
      "labelField": "name"
    },
    {
      "name": "__v",
      "type": "number",
      "label": "Version",
      "storage": {
        "kind": "number"
      },
      "readOnly": true,
      "hidden": true
    },
    {
      "name": "createdAt",
      "type": "date",
      "label": "Created At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "storage": {
        "kind": "date"
      },
      "readOnly": true
    }
  ],
  "views": {
    "list": {
      "fields": [
        {
          "name": "code",
          "role": "primary",
          "width": "fill"
        },
        {
          "name": "course"
        },
        {
          "name": "tenant"
        },
        {
          "name": "isActive"
        },
        {
          "name": "currentUses"
        },
        {
          "name": "maxUses"
        }
      ]
    },
    "detail": {
      "fields": [
        {
          "name": "_id"
        },
        {
          "name": "code"
        },
        {
          "name": "course"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "currentUses"
        },
        {
          "name": "isActive"
        },
        {
          "name": "maxUses"
        },
        {
          "name": "tenant"
        },
        {
          "name": "createdAt"
        },
        {
          "name": "updatedAt"
        }
      ]
    },
    "form": {
      "fields": [
        {
          "name": "code"
        },
        {
          "name": "course"
        },
        {
          "name": "createdBy"
        },
        {
          "name": "currentUses"
        },
        {
          "name": "isActive"
        },
        {
          "name": "maxUses"
        },
        {
          "name": "tenant"
        }
      ]
    }
  },
  "filters": [
    {
      "field": "code",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "course",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "tenant",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "isActive",
      "operators": [
        "equals"
      ]
    },
    {
      "field": "currentUses",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    },
    {
      "field": "maxUses",
      "operators": [
        "equals",
        "greater_than_equal",
        "less_than_equal"
      ]
    }
  ]
}
